{
    "http-request": {
        "path": "/generate-questions",
        "method": "POST",
        "headers": {
            "Content-Type": "application/json"
        },
        "body": {
            "role": "Machine Learning Engineer"
        }
    },
    "http-response": {
        "status": 200,
        "body": {
